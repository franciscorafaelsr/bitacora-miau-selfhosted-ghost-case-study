# ==============================================================================
# Mailgun Proxy Environment Variables (Template)
# ==============================================================================
# Copia este archivo a '.env' dentro de la carpeta 'mailgun-proxy' en producción.
# ==============================================================================

# Puerto de escucha del microservicio Express (por defecto 8020)
PORT=8020

# Entorno de Node.js (production o development)
NODE_ENV=production

# ------------------------------------------------------------------------------
# Configuración del Relé SMTP Upstream
# ------------------------------------------------------------------------------
# Nombre de usuario de autenticación SMTP (ej. en Brevo es la dirección de correo registrada)
BREVO_SMTP_USER=tu_usuario_smtp_aqui

# Contraseña de autenticación SMTP
BREVO_SMTP_PASSWORD=tu_contrasena_smtp_aqui

# ------------------------------------------------------------------------------
# Optimización de Envíos
# ------------------------------------------------------------------------------
# Número máximo de correos a incluir por cada lote individual enviado vía SMTP.
# Dividir una gran campaña en lotes evita bloquear la conexión o exceder límites.
CHUNK_SIZE=1000

# ------------------------------------------------------------------------------
# Observabilidad (Sentry Tracking)
# ------------------------------------------------------------------------------
# DSN provisto por Sentry para registrar excepciones e incidentes (ej. fallas SMTP o red)
SENTRY_DSN_MAILGUN_PROXY=

# Tasa de muestreo para trazas (de 0.0 a 1.0). Mantén en 0 en producción a menos 
# que requieras depurar problemas específicos (para evitar sobrecostos).
SENTRY_TRACES_SAMPLE_RATE=0
