# ==============================================================================
# Environment Variables Template - Bitácora Miau (Template)
# ==============================================================================
# Copia este archivo a '.env' y completa los valores antes de iniciar el stack.
# ==============================================================================

# Dominio público del blog (sin https:// ni '/' al final)
DOMAIN=example.com

# Zona Horaria del Sistema (ej. America/Mexico_City)
SYSTEM_TIMEZONE=UTC

# Versión de Ghost CMS (imagen Docker a desplegar)
GHOST_IMAGE=ghost:6.41.0-alpine

# ------------------------------------------------------------------------------
# Configuración de Base de Datos (MariaDB)
# ------------------------------------------------------------------------------
# Contraseña del usuario administrador 'root' de MySQL
MYSQL_ROOT_PASSWORD=un_password_muy_seguro_y_largo_para_root

# Contraseña del usuario 'ghost' para el CMS
MYSQL_PASSWORD=otro_password_seguro_para_el_usuario_ghost

# ------------------------------------------------------------------------------
# Correo Transaccional (Ghost core - SMTP directo para magic links y perfiles)
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.tuservidor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASSWORD=contrasena_smtp_aqui
MAIL_FROM="Bitácora Miau <noreply@example.com>"

# ------------------------------------------------------------------------------
# Correo Masivo / Newsletters (Vía mailgun-proxy)
# ------------------------------------------------------------------------------
# Credenciales del relay SMTP que usará el proxy para despachar campañas (ej. Brevo, Mailcow)
NEWSLETTER_SMTP_USER=usuario_smtp_de_brevo_o_mailcow
NEWSLETTER_SMTP_PASSWORD=contrasena_smtp_para_newsletter

# ------------------------------------------------------------------------------
# Procesamiento de Imágenes (imgproxy)
# ------------------------------------------------------------------------------
# Claves hexadecimales para firmar URLs criptográficamente y evitar ataques DDoS.
# Puedes generar valores válidos en la terminal ejecutando:
# echo $(openssl rand -hex 16)
IMGPROXY_KEY=generar_con_openssl_rand_hex_16_y_pegar_aqui
IMGPROXY_SALT=generar_con_openssl_rand_hex_16_y_pegar_aqui

# ------------------------------------------------------------------------------
# Observabilidad (Sentry)
# ------------------------------------------------------------------------------
# DSN de Sentry para capturar errores del mailgun-proxy
SENTRY_DSN_MAILGUN_PROXY=
# Tasa de muestreo (tracesSampleRate) para transacciones en el proxy (de 0.0 a 1.0)
SENTRY_TRACES_SAMPLE_RATE=0

